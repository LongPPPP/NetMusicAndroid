generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  // url 已在 prisma.config.ts 中配置（Prisma 7）
}

enum Role {
  USER
  ARTIST
}

enum Gender {
  UNKNOWN
  MALE
  FEMALE
}

model User {
  id        Int      @id @default(autoincrement())
  username  String
  password  String
  email     String   @unique
  avatar    String?
  role      Role     @default(USER)
  gender    Gender   @default(UNKNOWN)
  signature String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

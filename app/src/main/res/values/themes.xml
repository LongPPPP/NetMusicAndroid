<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 主应用生效主题：黑白风格，全局去紫 -->
    <style name="Theme.NetMusicAndroid" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <!-- 主题色：深灰替代默认紫色 -->
        <item name="colorPrimary">#212121</item>
        <item name="colorPrimaryDark">#000000</item>
        <item name="colorAccent">#424242</item>
        <!-- 全局背景白色 -->
        <item name="android:windowBackground">#FFFFFF</item>
    </style>

    <!-- 队友提供的Material3基础主题（备用，如需M3组件可切换主主题parent到此） -->
    <style name="Base.Theme.NetMusicAndroid" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- 如需自定义M3配色在这里添加 -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>
</resources>
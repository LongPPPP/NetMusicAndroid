<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_surface"
    android:paddingHorizontal="16dp"
    tools:context=".activity.SettingActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/include_bottom_player">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 顶部标题栏：高度80dp、顶部30dp边距 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="30dp">

                <ImageView
                    android:id="@+id/iv_back"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_back"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_centerVertical="true"
                    android:text="@string/text_setting_title"
                    android:textColor="@color/color_text_primary"
                    android:textSize="21sp"/>
            </RelativeLayout>

            <!-- 分组标题：账号 -->
            <TextView
                android:id="@+id/tvGroupAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/text_group_account"
                android:textColor="@color/color_text_tertiary"
                android:textSize="14sp"/>

            <!-- 修改个人信息 条目 -->
            <LinearLayout
                android:id="@+id/rlItemInfo"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivIconUser"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_user"
                    android:contentDescription="@string/cd_icon_user"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/text_modify_user_info"
                    android:textColor="@color/color_text_primary"
                    android:textSize="18sp"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    android:contentDescription="@string/cd_arrow_right"/>
            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:background="@color/color_divider"/>

            <!-- 退出登录 条目 -->
            <LinearLayout
                android:id="@+id/rlItemLogout"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivIconLogout"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_logout"
                    android:contentDescription="@string/cd_icon_logout"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/text_logout"
                    android:textColor="@color/color_text_primary"
                    android:textSize="18sp"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    android:contentDescription="@string/cd_arrow_right"/>
            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:background="@color/color_divider"/>

            <!-- 分组标题：通用 -->
            <TextView
                android:id="@+id/tvGroupCommon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/text_group_common"
                android:textColor="@color/color_text_tertiary"
                android:textSize="14sp"/>

            <!-- 修改主题 条目 -->
            <LinearLayout
                android:id="@+id/rlItemTheme"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivIconTheme"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_theme"
                    android:contentDescription="@string/cd_icon_theme"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/text_modify_theme"
                    android:textColor="@color/color_text_primary"
                    android:textSize="18sp"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    android:contentDescription="@string/cd_arrow_right"/>
            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:background="@color/color_divider"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 全局底部播放器 -->
    <include
        android:id="@+id/include_bottom_player"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        layout="@layout/layout_bottom_player"/>
</RelativeLayout>
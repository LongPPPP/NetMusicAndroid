<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:paddingHorizontal="16dp"
    tools:context=".activity.SettingActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 顶部标题栏 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="30dp">

                <!-- 返回箭头 -->
                <ImageView
                    android:id="@+id/ivBack"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_back"
                    android:contentDescription="@string/cd_back_btn"/>

                <!-- 页面标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ivBack"
                    android:text="@string/text_setting_title"
                    android:textColor="#000000"
                    android:textSize="24sp"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <!-- 分组标题：账号 -->
            <TextView
                android:id="@+id/tvGroupAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/text_group_account"
                android:textColor="#888888"
                android:textSize="14sp"/>

            <!-- 修改个人信息 条目 -->
            <RelativeLayout
                android:id="@+id/rlItemInfo"
                android:layout_width="match_parent"
                android:layout_height="64dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_user"
                    android:contentDescription="@string/cd_icon_user"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/ivIconInfo"
                    android:layout_marginStart="16dp"
                    android:text="@string/text_modify_user_info"
                    android:textColor="#111111"
                    android:textSize="18sp"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_arrow_right"
                    android:contentDescription="@string/cd_arrow_right"/>
            </RelativeLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:background="#EEEEEE"/>

            <!-- 退出登录 条目 -->
            <RelativeLayout
                android:id="@+id/rlItemLogout"
                android:layout_width="match_parent"
                android:layout_height="64dp">

                <ImageView
                    android:id="@+id/ivIconLogout"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_logout"
                    android:contentDescription="@string/cd_icon_logout"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/ivIconLogout"
                    android:layout_marginStart="16dp"
                    android:text="@string/text_logout"
                    android:textColor="#111111"
                    android:textSize="18sp"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_arrow_right"
                    android:contentDescription="@string/cd_arrow_right"/>
            </RelativeLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:background="#EEEEEE"/>

            <!-- 分组标题：通用 -->
            <TextView
                android:id="@+id/tvGroupCommon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/text_group_common"
                android:textColor="#888888"
                android:textSize="14sp"/>

            <!-- 修改主题 条目 -->
            <RelativeLayout
                android:id="@+id/rlItemTheme"
                android:layout_width="match_parent"
                android:layout_height="64dp">

                <ImageView
                    android:id="@+id/ivIconTheme"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_theme"
                    android:contentDescription="@string/cd_icon_theme"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/ivIconTheme"
                    android:layout_marginStart="16dp"
                    android:text="@string/text_modify_theme"
                    android:textColor="#111111"
                    android:textSize="18sp"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_arrow_right"
                    android:contentDescription="@string/cd_arrow_right"/>
            </RelativeLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:background="#EEEEEE"/>

            <!-- 底部留白，避开全局播放器 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 全局底部播放器 -->
    <include
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:layout_alignParentBottom="true"
        layout="@layout/layout_bottom_player"/>
</RelativeLayout>
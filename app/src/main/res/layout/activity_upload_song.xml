<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FF"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="上架新歌曲"
        android:textColor="#333333"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etSongName"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_edittext"
        android:hint="歌曲名称 (1-100字符)"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <!-- 选择封面按钮 -->
    <Button
        android:id="@+id/btnPickCover"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="选择封面图片 (可选)"
        android:textColor="#666666"
        app:layout_constraintTop_toBottomOf="@id/etSongName" />

    <TextView
        android:id="@+id/tvCoverPath"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="未选择封面"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/btnPickCover"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 选择歌曲按钮 -->
    <Button
        android:id="@+id/btnPickSong"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="选择 MP3 歌曲文件 *"
        android:textColor="#666666"
        app:layout_constraintTop_toBottomOf="@id/tvCoverPath" />

    <TextView
        android:id="@+id/tvSongPath"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="未选择歌曲文件"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/btnPickSong"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnSubmit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="48dp"
        android:background="@drawable/bg_login_button"
        android:text="立即上架"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/tvSongPath" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="24dp">

    <!-- 统一规范标题栏 -->
    <LinearLayout
        android:id="@+id/ll_title_bar"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginTop="30dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginStart="-24dp"
        android:layout_marginEnd="-24dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/cd_back_btn" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/title_upload_song"
            android:textColor="#111111"
            android:textSize="21sp" />

        <View
            android:layout_width="24dp"
            android:layout_height="1dp" />
    </LinearLayout>

    <EditText
        android:id="@+id/etSongName"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/ll_title_bar"
        android:background="@drawable/bg_edittext"
        android:hint="歌曲名称 (1-100字符)"
        android:paddingHorizontal="16dp" />

    <!-- 选择封面按钮 -->
    <Button
        android:id="@+id/btnPickCover"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="选择封面图片 (可选)"
        android:textColor="#666666"
        app:layout_constraintTop_toBottomOf="@id/etSongName" />

    <TextView
        android:id="@+id/tvCoverPath"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="未选择封面"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/btnPickCover"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 选择歌曲按钮 -->
    <Button
        android:id="@+id/btnPickSong"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="选择 MP3 歌曲文件 *"
        android:textColor="#666666"
        app:layout_constraintTop_toBottomOf="@id/tvCoverPath" />

    <TextView
        android:id="@+id/tvSongPath"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="未选择歌曲文件"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/btnPickSong"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnSubmit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="48dp"
        android:background="@drawable/bg_login_button"
        android:text="立即上架"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/tvSongPath" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
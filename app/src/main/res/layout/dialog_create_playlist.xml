<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/shape_dialog_bg"
    android:padding="24dp">

    <!-- 标题栏：新建歌单 + 关闭叉号 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_dialog_create_playlist_title"
            android:textSize="20sp"
            android:textColor="#000000"
            android:textStyle="bold"/>

        <ImageView
            android:id="@+id/ivClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_close_x"
            android:contentDescription="@string/cd_close_dialog"/>
    </RelativeLayout>

    <!-- 标签文字：歌单名称 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/text_playlist_name_label"
        android:textSize="15sp"
        android:textColor="#333333"
        android:layout_marginTop="20dp"/>

    <!-- 输入框 + 字数0/30 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/hint_input_playlist_name"
            android:inputType="text"
            android:maxLength="30"
            android:textSize="15sp"
            android:paddingHorizontal="14dp"
            android:background="@drawable/shape_dialog_et"/>

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_word_count_default"
            android:textSize="13sp"
            android:textColor="#999999"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="14dp"/>
    </RelativeLayout>

    <!-- 底部按钮行：取消 + 确认 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="28dp">

        <!-- 取消按钮 白底黑边框 -->
        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/text_btn_cancel"
            android:textSize="16sp"
            android:textColor="#111111"
            android:background="@drawable/shape_btn_cancel"/>

        <View
            android:layout_width="16dp"
            android:layout_height="match_parent"/>

        <!-- 确认按钮 纯黑底白字 -->
        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/text_btn_confirm"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/shape_btn_confirm"/>
    </LinearLayout>
</LinearLayout>